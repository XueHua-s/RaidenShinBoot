{
  "name": "raiden-shin-boot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm -r --sort build",
    "check": "pnpm -r --sort check",
    "dev:server": "pnpm --filter @raiden/server dev",
    "dev:bot": "pnpm --filter @raiden/bot dev",
    "dev:panel": "pnpm --filter @raiden/panel dev",
    "db:generate": "pnpm --filter @raiden/database db:generate",
    "db:migrate": "pnpm --filter @raiden/database db:migrate",
    "db:studio": "pnpm --filter @raiden/database db:studio"
  },
  "devDependencies": {
    "@types/node": "^22.18.12",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@types/react": "19",
        "@types/react-dom": "19",
        "react": "19",
        "react-dom": "19"
      }
    }
  }
}
