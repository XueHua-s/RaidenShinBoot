DATABASE_URL=postgres://raiden:raiden@localhost:5432/raiden_shin_boot
REDIS_URL=redis://localhost:6379
POSTGRES_CONTAINER_NAME=raiden-shin-postgres
POSTGRES_PORT=5432
REDIS_CONTAINER_NAME=raiden-shin-redis
REDIS_PORT=6379

# Telegram BotFather token，即机器人访问令牌。
BOT_TOKEN=
BOT_RUNTIME_MODE=
BOT_POLLING_CONCURRENCY=8
BOT_UPDATE_TIMEOUT_MS=120000
# 使用 POST /api/telegram/webhook 时，把这个值配置为 Telegram 的 secret_token。
BOOT_TELEGRAM_WEBHOOK_SECRET=

# OpenAI-compatible relay。填写你自己的 new-api/OpenAI-compatible /v1 endpoint。
BOOT_GATEWAY_PRESET=openai_compatible
BOOT_BASE_URL=https://api.example.com/v1
# chat 和 embedding 使用不同 relay host 时，可分别覆盖。
BOOT_CHAT_BASE_URL=
BOOT_EMBEDDING_BASE_URL=
BOOT_IMAGE_BASE_URL=
BOOT_SEARCH_PROVIDER=disabled
BOOT_SEARCH_BASE_URL=
BOOT_WIKIPEDIA_API_URL=https://zh.wikipedia.org/w/api.php
BOOT_MOEGIRL_API_URL=https://zh.moegirl.org.cn/api.php
BOOT_API_KEY=
BOOT_CHAT_API_KEY=
BOOT_EMBEDDING_API_KEY=
BOOT_IMAGE_API_KEY=
BOOT_SEARCH_API_KEY=
BOOT_CHAT_MODEL=gpt-5.5
# 嵌入/生图模型固定为 text-embedding-3-large 和 chatgpt-image-latest；不要配置模型名，调整 base URL/key 即可。
BOOT_SEARCH_MAX_RESULTS=5
BOOT_SEARCH_DEPTH=basic
BOOT_CHAT_TIMEOUT_MS=90000
BOOT_EMBEDDING_TIMEOUT_MS=30000
BOOT_IMAGE_TIMEOUT_MS=180000
BOOT_SEARCH_TIMEOUT_MS=15000
BOOT_QUEUE_PREFIX=raiden
BOOT_QUEUE_ENQUEUE_TIMEOUT_MS=2000
BOOT_TELEGRAM_WORKER_CONCURRENCY=1
BOOT_MEMORY_WORKER_CONCURRENCY=2
BOOT_MEMORY_ENRICHMENT_ASYNC_ENABLED=false
BOOT_SEMANTIC_CACHE_ENABLED=true
BOOT_SEMANTIC_CACHE_L1_ENABLED=true
BOOT_SEMANTIC_CACHE_L2_ENABLED=true
BOOT_SEMANTIC_CACHE_PREFIX=boot:semantic-cache
BOOT_SEMANTIC_CACHE_NAMESPACE=
BOOT_SEMANTIC_CACHE_TTL_SECONDS=86400
BOOT_SEMANTIC_CACHE_THRESHOLD=0.92
BOOT_SEMANTIC_CACHE_MAX_CANDIDATES=8
BOOT_SEMANTIC_CACHE_TIMEOUT_MS=750
# 在管理后台 System 页保存 API key 前必须设置。
BOOT_SETTINGS_ENCRYPTION_KEY=

SERVER_HOST=0.0.0.0
SERVER_PORT=8787
PANEL_PORT=5173
VITE_API_BASE_URL=http://localhost:8787
# 远程部署时填写面板访问源，多个用英文逗号分隔，例如 https://panel.example.com。
# 管理后台 cookie 为 SameSite=Strict；panel 与 API 应位于同一 site，例如 panel.example.com + api.example.com。
CORS_ALLOWED_ORIGINS=

# 管理员初始化和 session 配置。生产环境不要使用示例值。
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Owner
ADMIN_SESSION_COOKIE_NAME=raiden_admin_session
ADMIN_SESSION_TTL_HOURS=8
# HTTPS 生产部署必须设为 true；本地 http://localhost 测试可保持 false。
ADMIN_SECURE_COOKIES=false
