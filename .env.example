DATABASE_URL=postgres://raiden:raiden@localhost:5432/raiden_shin_boot

# Telegram BotFather token
BOT_TOKEN=

# OpenAI-compatible relay. This proxy requires streaming chat completions.
BOOT_GATEWAY_PRESET=openai_compatible
BOOT_BASE_URL=https://proxy.xhblog.top:3000/v1
# Optional override when chat and embedding are served by different relay hosts.
BOOT_CHAT_BASE_URL=
BOOT_EMBEDDING_BASE_URL=https://api.burn.hair/v1
BOOT_IMAGE_BASE_URL=https://api.burn.hair/v1
BOOT_SEARCH_PROVIDER=disabled
BOOT_SEARCH_BASE_URL=
BOOT_API_KEY=
BOOT_CHAT_API_KEY=
BOOT_EMBEDDING_API_KEY=
BOOT_IMAGE_API_KEY=
BOOT_SEARCH_API_KEY=
BOOT_CHAT_MODEL=gpt-5.5
BOOT_EMBEDDING_MODEL=text-embedding-3-large
BOOT_IMAGE_MODEL=gpt-image-1
BOOT_SEARCH_MAX_RESULTS=5
BOOT_SEARCH_DEPTH=basic
BOOT_CHAT_TIMEOUT_MS=90000
BOOT_EMBEDDING_TIMEOUT_MS=30000
BOOT_IMAGE_TIMEOUT_MS=180000
BOOT_SEARCH_TIMEOUT_MS=15000
# Required before saving API keys from the admin System page.
BOOT_SETTINGS_ENCRYPTION_KEY=

SERVER_HOST=0.0.0.0
SERVER_PORT=8787
PANEL_PORT=5173
VITE_API_BASE_URL=http://localhost:8787

# Admin bootstrap and session settings. Do not use these example values in production.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Owner
ADMIN_SESSION_COOKIE_NAME=raiden_admin_session
ADMIN_SESSION_TTL_HOURS=8
ADMIN_SECURE_COOKIES=false
