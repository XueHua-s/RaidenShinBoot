{
  "name": "@raiden/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --deps.never-bundle postgres --deps.never-bundle drizzle-orm",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx --conditions=source src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@raiden/boot": "workspace:*",
    "@raiden/shared": "workspace:*",
    "dotenv": "^17.2.3",
    "grammy": "^1.43.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.18.12",
    "typescript": "^5.9.3"
  },
  "tsdown": {
    "deps": {
      "onlyBundle": false
    }
  }
}
