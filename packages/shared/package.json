{
  "name": "@raiden/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./boot": {
      "source": "./src/boot.ts",
      "types": "./dist/boot.d.mts",
      "import": "./dist/boot.mjs"
    },
    "./persona": {
      "source": "./src/persona.ts",
      "types": "./dist/persona.d.mts",
      "import": "./dist/persona.mjs"
    },
    "./memory": {
      "source": "./src/memory.ts",
      "types": "./dist/memory.d.mts",
      "import": "./dist/memory.mjs"
    },
    "./schemas": {
      "source": "./src/schemas.ts",
      "types": "./dist/schemas.d.mts",
      "import": "./dist/schemas.mjs"
    },
    "./search": {
      "source": "./src/search.ts",
      "types": "./dist/search.d.mts",
      "import": "./dist/search.mjs"
    },
    "./tools": {
      "source": "./src/tools.ts",
      "types": "./dist/tools.d.mts",
      "import": "./dist/tools.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/boot.ts src/memory.ts src/persona.ts src/schemas.ts src/search.ts src/tools.ts --format esm --dts",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.64",
    "ai": "^6.0.185",
    "lodash-es": "^4.18.1",
    "p-limit": "^4.0.0",
    "robot3": "^1.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.18.12",
    "typescript": "^5.9.3"
  }
}
